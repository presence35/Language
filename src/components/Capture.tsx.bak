import { playAudioWithLang, playAudioUrl } from '../utils/audio';

interface TranslationResult {
  id: string;
  transcription: string;
  russianPhrase: string;
  englishPhrase: string;
  sourceLanguage: 'en' | 'ru';
  wordBreakdown: any[];
  audioUrl?: string | null;
  timestamp: number;
}

interface Animal {
  id: string;
  nameEn: string;
  nameRu: string;
  bgClass: string;
  borderClass: string;
  recordingBg: string;
  pulseColor: string;
  svg: React.ReactNode;
}

